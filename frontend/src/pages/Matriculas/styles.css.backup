/* src/pages/Matriculas/styles.css */

.input-pequeno {
  width: 80px;
}
/* Ajuste no flex do container para não espremer tudo */
.filtro-container-flex {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 15px;
  margin-bottom: 12px;
  background: #f8f9fa;
  padding: 8px;
  border-radius: 8px;
  flex-wrap: wrap; /* Permite quebrar linha em telas menores */
}

.busca-container {
  flex: 1; /* Faz o campo ocupar o espaço disponível no centro */
  max-width: 300px;  
}

.input-busca {
  width: 100%;
  padding: 8px 12px;
  border: 1px solid #ddd;
  border-radius: 6px;
  font-size: 14px;
  transition: border-color 0.2s;
}

.input-busca:focus {
  border-color: var(--primary);
  outline: none;
  box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.1);
}


.input-group-filtro {
  align-items: center;
  gap: 8px;
  font-size: 13px;
}

.status-emandamento {
  background: #e7f5ff;
  color: #1c7ed6;
}
.status-trancado {
  background: #fff9db;
  color: #f08c00;
}
.status-finalizado {
  background: #ebfbee;
  color: #2f9e44;
}

.status-pago {
  background: #d3f9d8;
  color: #2b8a3e;
}
.status-aberto {
  background: #fff3bf;
  color: #e67700;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 8px;
  width: 95%;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  overflow: hidden;
}

.modal-header {
  padding: 12px 15px;
  background: var(--dark);
  color: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-header h3 {
  margin: 0;
  font-size: 1rem;
}

.btn-fechar {
  background: none;
  border: none;
  color: white;
  cursor: pointer;
  font-size: 1.2rem;
}

.txt-detalhe-vermelho {
  color: #c41010;
  font-size: 12px;
}
.txt-detalhe-azul {
  color: var(--primary);
  font-size: 12px;
}

.texto-centralizado {
  text-align: center;
  padding: 30px;
  color: #aaa;
}


